# ============================================================
# AIManagePlatform 环境变量配置示例
# ------------------------------------------------------------
# 使用方法：复制本文件为 .env 并填入真实值，或直接在系统/容器中设置这些变量。
# .env 文件已被 gitignore，不会被提交。
# ============================================================

# ---- LLM 服务（智谱 GLM）----
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_DEFAULT_MODEL=glm-5.1
LLM_VERIFY_SSL=true
LLM_DEBUG=false

# ---- 管理接口鉴权 ----
ADMIN_TOKEN=your_admin_token_here

# ---- JWT 签名密钥（生产必填，留空则回退到 ADMIN_TOKEN，都为空则随机生成且重启后失效）----
JWT_SECRET_KEY=your_jwt_secret_key_here

# ---- 限流 ----
CHAT_RATE_LIMIT=30/minute

# ---- 服务运行 ----
APP_PORT=8002
MAX_DEVICES_PER_KEY=50

# ---- CORS 跨域 ----
# 逗号分隔的允许源，留空表示允许全部（通配时强制关闭 credentials）
# 生产建议：CORS_ORIGINS=https://your-frontend.com,http://localhost:3000
CORS_ORIGINS=
CORS_CREDENTIALS=true

# ---- 数据存储 ----
MAX_CHAT_HISTORY_SIZE=10485760
